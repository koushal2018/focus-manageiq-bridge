        </mxCell>
        <mxCell id="step-7-badge-legend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="7" vertex="1" parent="step-7-legend">
          <mxGeometry height="38" width="40" y="2" as="geometry" />
        </mxCell>
        <mxCell id="step-7-desc-legend" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;NL query - optional, fail-closed&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Free-text questions go to Amazon Bedrock behind a parser-level SQL allowlist; the platform is fully functional with this layer off. me-central-1 requires the global inference profile (residency gate B-1).&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="step-7-legend">
          <mxGeometry height="80" width="548" x="52" as="geometry" />
        </mxCell>
        <mxCell id="legend-note" style="text;html=1;align=left;verticalAlign=top;fontSize=13;fontStyle=2;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Region is parameterized: pilot runs on synthetic data in us-east-1; production real-data deployment is me-central-1 (UAE residency, P-1). Carbon and the AI layer are explicit opt-ins, not defaults.&lt;/span&gt;" vertex="1" parent="legend-container">
          <mxGeometry height="50" width="600" x="0" y="630" as="geometry" />
        </mxCell>
