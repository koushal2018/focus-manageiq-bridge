        <mxCell id="step-1-desc-legend" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;Cost exports land&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;AWS CUR 2.0 (FOCUS-native), Azure cost export, and OCI usage report are delivered on schedule to the S3 raw landing zone (versioned, KMS-encrypted).&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="step-1-legend">
          <mxGeometry height="80" width="548" x="52" as="geometry" />
        </mxCell>
        <mxCell id="step-2-legend" connectable="0" style="group;fontFamily=Helvetica;" value="" vertex="1" parent="legend-container">
          <mxGeometry height="80" width="600" x="0" y="90" as="geometry" />
        </mxCell>
        <mxCell id="step-2-badge-legend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="2" vertex="1" parent="step-2-legend">
          <mxGeometry height="38" width="40" y="2" as="geometry" />
        </mxCell>
        <mxCell id="step-2-desc-legend" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;Connector dispatcher fetches&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;ROSA workers read the connector registry and pull new exports on schedule, resolving credentials from Secrets Manager (no raw secrets in config - add a source without a deploy).&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="step-2-legend">
          <mxGeometry height="80" width="548" x="52" as="geometry" />
        </mxCell>
        <mxCell id="step-3-legend" connectable="0" style="group;fontFamily=Helvetica;" value="" vertex="1" parent="legend-container">
          <mxGeometry height="80" width="600" x="0" y="180" as="geometry" />
        </mxCell>
        <mxCell id="step-3-badge-legend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="3" vertex="1" parent="step-3-legend">
          <mxGeometry height="38" width="40" y="2" as="geometry" />
        </mxCell>
        <mxCell id="step-3-desc-legend" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;Normalize + load&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Provider-native rows are normalized to FOCUS v1.3, pass row-level conformance validation, and load into Aurora PostgreSQL (Multi-AZ, KMS at rest, PITR) - the PoC schema unchanged.&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="step-3-legend">
          <mxGeometry height="80" width="548" x="52" as="geometry" />
        </mxCell>
        <mxCell id="step-4-legend" connectable="0" style="group;fontFamily=Helvetica;" value="" vertex="1" parent="legend-container">
          <mxGeometry height="80" width="600" x="0" y="270" as="geometry" />
        </mxCell>
        <mxCell id="step-4-badge-legend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="4" vertex="1" parent="step-4-legend">
          <mxGeometry height="38" width="40" y="2" as="geometry" />
        </mxCell>
        <mxCell id="step-4-desc-legend" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;On-prem collection&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;The MIQ collector pulls ManageIQ inventory, utilization (C&amp;amp;U) and chargeback over Direct Connect / VPN - TLS verified, never over the public internet. On-prem rows join cloud costs via resource_join_map.&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="step-4-legend">
          <mxGeometry height="80" width="548" x="52" as="geometry" />
        </mxCell>
        <mxCell id="step-5-legend" connectable="0" style="group;fontFamily=Helvetica;" value="" vertex="1" parent="legend-container">
          <mxGeometry height="80" width="600" x="0" y="360" as="geometry" />
        </mxCell>
        <mxCell id="step-5-badge-legend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="5" vertex="1" parent="step-5-legend">
          <mxGeometry height="38" width="40" y="2" as="geometry" />
        </mxCell>
        <mxCell id="step-5-desc-legend" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;Private user access&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;ENBD users authenticate via ENBD IdP (SAML/OIDC SSO); traffic passes WAF to the private web tier. No public exposure - bank posture.&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="step-5-legend">
          <mxGeometry height="80" width="548" x="52" as="geometry" />
        </mxCell>
        <mxCell id="step-6-legend" connectable="0" style="group;fontFamily=Helvetica;" value="" vertex="1" parent="legend-container">
          <mxGeometry height="80" width="600" x="0" y="450" as="geometry" />
        </mxCell>
        <mxCell id="step-6-badge-legend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="6" vertex="1" parent="step-6-legend">
          <mxGeometry height="38" width="40" y="2" as="geometry" />
        </mxCell>
        <mxCell id="step-6-desc-legend" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;Four-view dashboard&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;The stateless FastAPI web tier on ROSA (the PoC image, unchanged) serves the four-view console with read-only queries against Aurora.&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="step-6-legend">
          <mxGeometry height="80" width="548" x="52" as="geometry" />
        </mxCell>
        <mxCell id="step-7-legend" connectable="0" style="group;fontFamily=Helvetica;" value="" vertex="1" parent="legend-container">
