# Copy to .env and adjust. docker-compose reads it automatically.
# All defaults are safe for a local synthetic-data demo.

# --- FOCUS database ---
FOCUS_PG_USER=focus_app
FOCUS_PG_PASS=focus_app_demo
FOCUS_PG_DB=focus

# --- Web ---
WEB_PORT=8000

# --- Bedrock NL-query (optional; off by default) ---
# Set to 0 AND provide AWS credentials to the web container to enable the
# free-text path. Region/model are read by ai/bedrock_client.py.
# me-central-1 is global-inference-profile only (GOTCHA B-1).
BEDROCK_DISABLED=1
# BEDROCK_REGION=us-east-1
# BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-6
