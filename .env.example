# Copy to .env for local docker-compose overrides. .env is git-ignored.
# All defaults (in docker-compose.yml) are SAFE for a local synthetic-data demo.

# --- FOCUS database ---
FOCUS_PG_USER=focus_app
FOCUS_PG_PASS=focus_app_demo
FOCUS_PG_DB=focus

# --- Web ---
WEB_PORT=8000
# Demo data volume (per-day row multiplier). 8 is a credible dashboard; 1 is
# the fast hand-traceable / CI size.
FOCUS_GEN_SCALE=8

# --- Bedrock NL-query (OPTIONAL; OFF by default) ---
# The free-text NL->SQL path is OPT-IN. Leave it OFF unless you have reviewed
# the SQL guard and accept the residency posture (GOTCHA B-1: me-central-1 has
# no Claude on-demand; us-east-1 cross-region inference profile is used).
# Wrong-cost-with-confident-narration is the worst outcome for a bank (SPEC 0),
# so this is off by default and you enable it knowingly. The canned queries and
# the whole dashboard work fully WITHOUT this.
# BEDROCK_DISABLED=0                                 # uncomment to ENABLE
# BEDROCK_REGION=us-east-1
# BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# --- Tenant branding / reporting currency (see config/tenant.json) ---
# TENANT_ORG_NAME=Acme Bank
# TENANT_PRODUCT_NAME=CloudLens FinOps

# --- App-layer Basic Auth on the (destructive) console — set BOTH to enable ---
# BASIC_AUTH_USER=
# BASIC_AUTH_PASS=
